# Copy to .env and fill in real values. Never commit the real .env file.

# --- Database (Neon) ---
# DATABASE_URL = pooled connection (hostname suffixed `-pooler`) — used at runtime.
#                Neon console > project > Connect > check "Pooled connection".
# DIRECT_URL   = direct connection (no `-pooler` suffix) — used only for `prisma migrate`.
#                Neon console > project > Connect > uncheck "Pooled connection".
DATABASE_URL=
DIRECT_URL=

# --- Auth ---
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
# Used only by prisma/seed.ts to create the one admin account — public
# registration (/api/auth/register) can never create an ADMIN.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# --- Paystack ---
# Use test-mode keys for local/dev, live keys only in production.
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=

# --- Resend (transactional email) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@lobyluwa.com

# --- WhatsApp (click-to-chat only, no Business API — see docs/TRD.md section 4) ---
BUSINESS_WHATSAPP_NUMBER=

# --- Cloudinary (product image hosting) ---
CLOUDINARY_CLOUD_NAME=
# Same value as above, exposed to the browser to build image URLs directly
# (cloud name isn't secret — the API key/secret above are what stay server-only).
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Upstash Redis (rate limiting) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Sentry (error tracking) ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
