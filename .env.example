# Copy to .env and fill in real values. Never commit the real .env file.

# --- Database (Supabase) ---
# DATABASE_URL = pooled connection via Supavisor (Supabase's pooler) — used at runtime.
#                Project Settings > Database > Connection string > "Transaction" mode.
# DIRECT_URL   = direct connection — used only for `prisma migrate`.
#                Project Settings > Database > Connection string > "Direct connection".
DATABASE_URL=
DIRECT_URL=

# --- Auth ---
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# --- Paystack ---
# Use test-mode keys for local/dev, live keys only in production.
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=

# --- Resend (transactional email) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@lobyluwa.com

# --- Cloudinary (product image hosting) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Upstash Redis (rate limiting) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Sentry (error tracking) ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
